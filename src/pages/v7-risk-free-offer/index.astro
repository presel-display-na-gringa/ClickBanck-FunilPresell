---
const imagePath = '/images/presell/v7-risk-free-offer';
const affiliateLink = 'https://c2d6ddnxbtgz2r61fh0em90ofn.hop.clickbank.net/';

const offers = [
  {
    id: 'one-bottle',
    badge: 'Try it out',
    title: '1 Bottle',
    supply: '30 Day Supply',
    image: `${imagePath}/1-bottle-30-day-supply.webp`,
    price: '$69',
    priceLabel: 'per bottle',
    total: '$69',
    popular: false,
    cta: 'Choose 1 Bottle',
    href: affiliateLink,
  },
  {
    id: 'three-bottles',
    badge: 'Most Popular',
    title: '3 Bottles',
    supply: '90 Day Supply',
    image: `${imagePath}/3-bottle-90-day-supply-card.webp`,
    price: '$59',
    priceLabel: 'per bottle',
    total: '$177',
    savings: 'Save $30',
    popular: true,
    cta: 'Choose 3 Bottles',
    href: affiliateLink,
  },
  {
    id: 'six-bottles',
    badge: 'Best Value',
    title: '6 Bottles',
    supply: '180 Day Supply',
    image: `${imagePath}/6-bottle-180-day-supply.webp`,
    price: '$39',
    priceLabel: 'per bottle',
    total: '$234',
    savings: 'Save $180',
    popular: false,
    cta: 'Choose 6 Bottles',
    href: affiliateLink,
  },
];

const testimonials = [
  {
    name: 'Courtney',
    image: `${imagePath}/courtney.webp`,
    text: '"I liked adding this routine to my day. It’s simple, practical, and fits well with my schedule."',
  },
  {
    name: 'John',
    image: `${imagePath}/john.webp`,
    text: '"The checkout experience was straightforward, and the usage guidelines helped me keep my routine organized."',
  },
  {
    name: 'Rina',
    image: `${imagePath}/rina.webp`,
    text: '"The 90-day option was the best fit for my planning and daily routine."',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Choose Your Option | Okinawa Tonic</title>
    <meta
      name="description"
      content="Choose the Okinawa Tonic option that best fits your routine."
    />

    <meta name="robots" content="index, follow" />

    <!-- Google Tag Manager -->
    <script is:inline>
      (function (w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != 'dataLayer' ? '&l=' + l : '';
        j.async = true;
        j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, 'script', 'dataLayer', 'GTM-MZGS6TFK');
    </script>
    <!-- End Google Tag Manager -->

    <!-- Google tag (gtag.js) - GA4 and Google Ads -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-YP7930G972"></script>
    <script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-YP7930G972');
  gtag('config', 'AW-18062534244');
</script>
  </head>

  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript>
      <iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-MZGS6TFK"
        height="0"
        width="0"
        style="display:none;visibility:hidden"
      ></iframe>
    </noscript>
    <!-- End Google Tag Manager (noscript) -->

    <header class="topbar">
      <div class="container topbar__content">
        <span class="topbar__brand">NaturalTonicRoutine</span>
        <span>Secure checkout experience</span>
        <span class="topbar__secure">🔒 Protected purchase</span>
      </div>
      <div class="container topbar__affiliate">
        <span>
          Affiliate Disclosure: This page may contain affiliate links. If you
          purchase through these links, we may earn a commission at no
          additional cost to you.
        </span>
      </div>
    </header>

    <main>
      <section class="hero">
        <div class="container hero__grid">
          <div class="hero__content">
            <p class="eyebrow">DAILY WELLNESS ROUTINE</p>

            <h1>Choose the option that best fits your routine.</h1>

            <p class="hero__description">
              Select your preferred Okinawa Tonic supply and proceed to a
              simple, secure checkout experience.
            </p>

            <ul class="check-list">
              <li>Simple daily routine</li>
              <li>Choose the option that best fits you</li>
              <li>Secure checkout process</li>
            </ul>

            <a class="button button--primary" href={affiliateLink} target="_blank" rel="noopener noreferrer">
              See Available Options
            </a>
          </div>

          <div class="hero__media">
            <img
              src={`${imagePath}/woman-enjoying-drink.webp`}
              alt="Woman enjoying a drink during her routine"
              width="720"
              height="720"
              fetchpriority="high"
            />
          </div>
        </div>
      </section>

      <section class="routine-section">
        <div class="container routine-section__grid">
          <div class="routine-section__media">
            <img
              src={`${imagePath}/woman-preparing-okinawa-tonic.webp`}
              alt="Woman preparing a drink in her kitchen"
              width="720"
              height="720"
              loading="lazy"
            />
          </div>

          <div class="routine-section__content">
            <p class="eyebrow">A SIMPLIFIED ROUTINE</p>

            <h2>
              Consistency starts with a routine you can actually follow.
            </h2>

            <p>
              Choose the option that best fits your daily schedule. Having a
              clear plan can help you keep a simpler, more predictable
              routine.
            </p>

            <p>
              Before completing your purchase, review the product
              information, ingredients, usage instructions, and available
              policies.
            </p>
          </div>
        </div>
      </section>

      <section class="offers-section" id="offers">
        <div class="container">
          <div class="section-heading">
            <p class="eyebrow">SELECT YOUR SUPPLY</p>
            <h2>Available Okinawa Tonic Options</h2>
            <p>
              Choose the option that best matches your routine and purchase
              preference.
            </p>
          </div>

          <div class="offers-grid">
            {
              offers.map((offer) => (
                <article
                  class:list={[
                    'offer-card',
                    offer.popular && 'offer-card--popular',
                  ]}
                >
                  <div class="offer-card__badge">{offer.badge}</div>

                  <div class="offer-card__content">
                    <h3>{offer.title}</h3>
                    <p class="offer-card__supply">{offer.supply}</p>

                    <img
                      class="offer-card__image"
                      src={offer.image}
                      alt={`${offer.title} of Okinawa Tonic — ${offer.supply}`}
                      width="520"
                      height="520"
                      loading="lazy"
                    />

                    <div class="offer-card__price">
                      <span class="offer-card__price-value">{offer.price}</span>
                      <span class="offer-card__price-label">
                        {offer.priceLabel}
                      </span>
                    </div>

                    <p class="offer-card__total">
                      Total: <strong>{offer.total}</strong>
                    </p>

                    {
                      offer.savings && (
                        <p class="offer-card__savings">{offer.savings}</p>
                      )
                    }

                    <a
                      class="button button--offer"
                      href={offer.href}
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      {offer.cta}
                    </a>
                  </div>
                </article>
              ))
            }
          </div>

          <div class="guarantee">
            <div class="guarantee__media">
              <img
                src={`${imagePath}/okinawa-90-day-guarantee.webp`}
                alt="90-day guarantee seal"
                width="320"
                height="320"
                loading="lazy"
              />
            </div>

            <div class="guarantee__content">
              <p class="eyebrow">SHOP WITH MORE PEACE OF MIND</p>
              <h2>Review the guarantee terms before checking out.</h2>
              <p>
                Carefully read the applicable conditions, timeframes, and
                supplier instructions before completing your order.
              </p>
              <a class="text-link" href="#guarantee-terms">
                View Guarantee Terms <span aria-hidden="true">→</span>
              </a>
            </div>
          </div>
        </div>
      </section>

      <section class="lifestyle-section">
        <div class="container lifestyle-section__grid">
          <div class="lifestyle-section__content">
            <p class="eyebrow">EVERYDAY WELLNESS</p>
            <h2>Small choices can be part of a balanced routine.</h2>
            <p>
              Nutrition, movement, rest, and consistency are elements that can
              contribute to a more mindful wellness routine.
            </p>
          </div>

          <div class="lifestyle-section__media">
            <img
              src={`${imagePath}/couple-running-healthy-lifestyle.webp`}
              alt="Couple running outdoors during physical activity"
              width="900"
              height="680"
              loading="lazy"
            />
          </div>
        </div>
      </section>

      <section class="testimonials-section">
        <div class="container">
          <div class="section-heading">
            <p class="eyebrow">SHARED EXPERIENCES</p>
            <h2>What some people say about the routine</h2>
          </div>

          <div class="testimonials-grid">
            {
              testimonials.map((testimonial) => (
                <article class="testimonial-card">
                  <img
                    src={testimonial.image}
                    alt={`Photo of ${testimonial.name}`}
                    width="160"
                    height="160"
                    loading="lazy"
                  />

                  <div>
                    <p>{testimonial.text}</p>
                    <strong>{testimonial.name}</strong>
                  </div>
                </article>
              ))
            }
          </div>

          <p class="disclaimer">
            Testimonials represent individual experiences and do not
            constitute a promise of results. Experiences may vary from person
            to person.
          </p>
        </div>
      </section>

      <section class="final-offer">
        <div class="container final-offer__grid">
          <div>
            <p class="eyebrow">READY TO CHOOSE?</p>
            <h2>Select the option that fits your routine.</h2>
            <p>
              Compare the available supplies and proceed to a secure order
              checkout.
            </p>

            <a class="button button--primary" href={affiliateLink} target="_blank" rel="noopener noreferrer">
              See Available Options
            </a>
          </div>

          <img
            src={`${imagePath}/okinawa-3-bottles-white-background.webp`}
            alt="Kit with three bottles of Okinawa Tonic"
            width="620"
            height="520"
            loading="lazy"
          />
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="container">
        <p>
          © {new Date().getFullYear()} Okinawa Tonic. All rights reserved.
        </p>

        <nav aria-label="Legal links">
          <a href="https://www.naturaltonicroutine.com/privacy-policy" target="_blank" rel="noopener noreferrer">Privacy Policy</a>
          <a href="https://www.naturaltonicroutine.com/disclaimer" target="_blank" rel="noopener noreferrer">Disclaimer</a>
          <a href="https://www.naturaltonicroutine.com/affiliate-disclosure" target="_blank" rel="noopener noreferrer">Affiliate Disclosure</a>
          <a href="https://www.naturaltonicroutine.com/contact" target="_blank" rel="noopener noreferrer">Contact</a>
        </nav>

        <p class="footer__notice">
          This website is for educational and informational purposes only. It
          may contain affiliate links, and we may receive a commission from
          qualifying purchases made through those links at no additional cost
          to you. Always review official product information and consult a
          qualified healthcare professional when appropriate.
        </p>
      </div>
    </footer>
  </body>
</html>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(html) {
    scroll-behavior: smooth;
  }

  :global(body) {
    margin: 0;
    min-width: 320px;
    color: #12352f;
    background: #ffffff;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
    font-size: 16px;
    line-height: 1.6;
  }

  :global(img) {
    display: block;
    max-width: 100%;
  }

  :global(a) {
    color: inherit;
  }

  .container {
    width: min(1160px, calc(100% - 40px));
    margin: 0 auto;
  }

  .topbar {
    padding: 10px 0;
    color: #ffffff;
    background: #103f37;
    font-size: 0.78rem;
    font-weight: 700;
  }

  .topbar__content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .topbar__brand {
    color: #ffffff;
    font-weight: 900;
    letter-spacing: 0.02em;
  }

  .topbar__secure {
    color: #f4d88c;
  }

  .topbar__affiliate {
    padding-top: 6px;
    color: #d9ece5;
    font-size: 0.7rem;
    font-weight: 500;
    text-align: center;
  }

  .hero {
    overflow: hidden;
    padding: 92px 0;
    background:
      radial-gradient(circle at 85% 20%, rgba(184, 225, 206, 0.7), transparent 28%),
      #f2f8f3;
  }

  .hero__grid,
  .routine-section__grid,
  .lifestyle-section__grid,
  .final-offer__grid {
    display: grid;
    grid-template-columns: 1fr 0.9fr;
    align-items: center;
    gap: clamp(40px, 7vw, 100px);
  }

  .hero__content {
    max-width: 630px;
  }

  .eyebrow {
    margin: 0 0 14px;
    color: #16806e;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.14em;
  }

  h1,
  h2,
  h3 {
    margin-top: 0;
    color: #103a34;
    font-family: Georgia, "Times New Roman", serif;
    font-weight: 700;
    line-height: 1.06;
  }

  h1 {
    max-width: 650px;
    margin-bottom: 24px;
    font-size: clamp(2.55rem, 5vw, 4.7rem);
  }

  h2 {
    margin-bottom: 20px;
    font-size: clamp(2rem, 3.5vw, 3.2rem);
  }

  h3 {
    margin-bottom: 8px;
    font-size: 1.75rem;
  }

  .hero__description,
  .routine-section__content p,
  .lifestyle-section__content p,
  .final-offer p {
    max-width: 590px;
    color: #45605a;
    font-size: 1.06rem;
  }

  .check-list {
    display: grid;
    gap: 10px;
    margin: 28px 0 32px;
    padding: 0;
    list-style: none;
    font-weight: 650;
  }

  .check-list li {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .check-list li::before {
    display: grid;
    width: 20px;
    height: 20px;
    flex: 0 0 20px;
    place-items: center;
    border-radius: 50%;
    color: #ffffff;
    background: #19836f;
    content: "✓";
    font-size: 0.75rem;
    font-weight: 900;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 14px 22px;
    border-radius: 7px;
    text-decoration: none;
    font-weight: 800;
    transition:
      transform 0.2s ease,
      background-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .button:hover {
    transform: translateY(-2px);
  }

  .button--primary {
    color: #ffffff;
    background: #c65f34;
    box-shadow: 0 10px 20px rgba(152, 67, 34, 0.18);
  }

  .button--primary:hover {
    background: #a94e2a;
  }

  .hero__media img,
  .routine-section__media img,
  .lifestyle-section__media img {
    width: 100%;
    object-fit: cover;
    box-shadow: 0 20px 45px rgba(19, 58, 51, 0.14);
  }

  .hero__media img {
    aspect-ratio: 1 / 1;
    border-radius: 12px;
  }

  .routine-section {
    padding: 105px 0;
  }

  .routine-section__media {
    order: 1;
  }

  .routine-section__content {
    order: 2;
  }

  .routine-section__media img {
    aspect-ratio: 1 / 1;
    border-radius: 10px;
  }

  .offers-section {
    padding: 100px 0;
    background: #f7faf7;
  }

  .section-heading {
    max-width: 720px;
    margin: 0 auto 46px;
    text-align: center;
  }

  .section-heading h2 {
    margin-bottom: 14px;
  }

  .section-heading > p:last-child {
    margin: 0;
    color: #58706a;
  }

  .offers-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    align-items: stretch;
    gap: 22px;
  }

  .offer-card {
    position: relative;
    overflow: hidden;
    border: 1px solid #d6e4dd;
    border-radius: 12px;
    background: #ffffff;
    box-shadow: 0 12px 25px rgba(25, 61, 53, 0.06);
  }

  .offer-card--popular {
    border: 2px solid #c65f34;
    box-shadow: 0 16px 35px rgba(174, 76, 38, 0.14);
  }

  .offer-card__badge {
    min-height: 38px;
    padding: 10px 12px;
    color: #ffffff;
    background: #155f52;
    text-align: center;
    font-size: 0.78rem;
    font-weight: 850;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .offer-card--popular .offer-card__badge {
    background: #c65f34;
  }

  .offer-card__content {
    display: flex;
    height: calc(100% - 38px);
    flex-direction: column;
    align-items: center;
    padding: 26px 22px 24px;
    text-align: center;
  }

  .offer-card__supply {
    min-height: 26px;
    margin: 0;
    color: #658078;
    font-size: 0.92rem;
  }

  .offer-card__image {
    width: min(100%, 260px);
    height: 220px;
    margin: 18px 0 12px;
    object-fit: contain;
  }

  .offer-card__price {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 7px;
  }

  .offer-card__price-value {
    color: #126451;
    font-size: 2.5rem;
    font-weight: 900;
    line-height: 1;
  }

  .offer-card__price-label,
  .offer-card__total {
    color: #58716b;
    font-size: 0.86rem;
  }

  .offer-card__total {
    margin: 12px 0 0;
  }

  .offer-card__savings {
    min-height: 25px;
    margin: 8px 0 14px;
    color: #b4512b;
    font-size: 0.86rem;
    font-weight: 800;
  }

  .offer-card__total + .button--offer {
    margin-top: 22px;
  }

  .button--offer {
    width: 100%;
    margin-top: auto;
    color: #ffffff;
    background: #155f52;
  }

  .offer-card--popular .button--offer {
    background: #c65f34;
  }

  .button--offer:hover {
    background: #0e4a3f;
  }

  .offer-card--popular .button--offer:hover {
    background: #a94e2a;
  }

  .guarantee {
    display: grid;
    grid-template-columns: 180px 1fr;
    align-items: center;
    gap: 38px;
    max-width: 860px;
    margin: 72px auto 0;
    padding: 30px;
    border: 1px solid #d7e4dc;
    border-radius: 14px;
    background: #ffffff;
  }

  .guarantee__media {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .guarantee__media img {
    display: block;
    width: 100%;
    max-width: 320px;
    height: auto;
    margin: 0 auto;
    object-fit: contain;
    aspect-ratio: auto;
  }

  .guarantee h2 {
    margin-bottom: 12px;
    font-size: clamp(1.7rem, 3vw, 2.4rem);
  }

  .guarantee p:not(.eyebrow) {
    color: #557069;
  }

  .text-link {
    color: #146a59;
    font-weight: 800;
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
  }

  .lifestyle-section {
    padding: 105px 0;
    background: #ffffff;
  }

  .lifestyle-section__media img {
    aspect-ratio: 4 / 3;
    border-radius: 12px;
  }

  .testimonials-section {
    padding: 100px 0;
    background: #eaf4ed;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
  }

  .testimonial-card {
    display: grid;
    grid-template-columns: 68px 1fr;
    align-items: start;
    gap: 17px;
    padding: 25px;
    border-radius: 12px;
    background: #ffffff;
  }

  .testimonial-card img {
    width: 68px;
    height: 68px;
    border-radius: 50%;
    object-fit: cover;
  }

  .testimonial-card p {
    margin: 0 0 12px;
    color: #48625b;
    font-size: 0.96rem;
  }

  .testimonial-card strong {
    color: #174b41;
  }

  .disclaimer {
    max-width: 800px;
    margin: 35px auto 0;
    color: #5e756e;
    font-size: 0.8rem;
    text-align: center;
  }

  .final-offer {
    padding: 88px 0;
    overflow: hidden;
    color: #ffffff;
    background: #123f37;
  }

  .final-offer h2,
  .final-offer p {
    color: #ffffff;
  }

  .final-offer img {
    width: min(100%, 470px);
    max-height: 360px;
    margin: 0 auto;
    object-fit: contain;
  }

  .footer {
    padding: 38px 0;
    color: #b8cec7;
    background: #0d2924;
    font-size: 0.86rem;
    text-align: center;
  }

  .footer p {
    margin: 0;
  }

  .footer nav {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 16px;
    margin: 16px 0;
  }

  .footer a {
    color: #ffffff;
    text-decoration: none;
  }

  .footer a:hover {
    text-decoration: underline;
  }

  .footer__notice {
    max-width: 760px;
    margin: 0 auto !important;
    font-size: 0.78rem;
  }

  @media (max-width: 900px) {
    .hero,
    .routine-section,
    .offers-section,
    .lifestyle-section,
    .testimonials-section {
      padding: 72px 0;
    }

    .hero__grid,
    .routine-section__grid,
    .lifestyle-section__grid,
    .final-offer__grid {
      grid-template-columns: 1fr;
      gap: 42px;
    }

    .hero__media {
      max-width: 520px;
      margin: 0 auto;
    }

    .routine-section__media,
    .routine-section__content {
      order: initial;
    }

    .offers-grid,
    .testimonials-grid {
      grid-template-columns: 1fr;
      max-width: 520px;
      margin: 0 auto;
    }

    .lifestyle-section__media {
      order: -1;
    }

    .final-offer {
      padding: 70px 0;
      text-align: center;
