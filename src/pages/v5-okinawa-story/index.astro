      :root {
        --sage:   #4a7c59;
        --sage2:  #5c9970;
        --sage3:  #e8f2eb;
        --amber:  #c8823a;
        --amber2: #e8a050;
        --cream:  #faf7f2;
        --warm:   #f2ede4;
        --navy:   #1c2b3a;
        --navy2:  #253849;
        --text:   #2a2a2a;
        --muted:  #6b6b6b;
        --border: #e0d9ce;
        --teal:   #2a9d8f;
        --teal2:  #21867a;
      }

      html { scroll-behavior: smooth; }

      body {
        font-family: 'Georgia', serif;
        background: var(--cream);
        color: var(--text);
        font-size: 17px;
        line-height: 1.85;
      }

      .progress-bar {
        position: fixed; top: 0; left: 0;
        height: 3px; width: 0%;
        background: linear-gradient(90deg, var(--sage), var(--amber));
        z-index: 9999;
        transition: width 0.12s ease;
      }

      .top-notice {
        background: var(--sage);
        color: #fff;
        text-align: center;
        padding: 9px 16px;
        font-family: Arial, sans-serif;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.04em;
      }

      .top-notice span { color: var(--amber2); }

      .masthead {
        background: #fff;
        border-bottom: 3px solid var(--sage);
      }

      .masthead-inner {
        max-width: 900px;
        margin: 0 auto;
        padding: 18px 20px 0;
      }

      .masthead-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 10px;
        padding-bottom: 16px;
        border-bottom: 1px solid var(--border);
      }

      .logo-wrap {
        display: flex;
        flex-direction: column;
      }

      .logo-name {
        color: var(--navy);
        font-family: Georgia, serif;
        font-size: 30px;
        font-weight: 700;
        letter-spacing: -1px;
        line-height: 1;
        text-decoration: none;
      }

      .logo-name em {
        color: var(--sage);
        font-style: normal;
      }

      .logo-name:hover,
      .logo-name:focus-visible {
        color: var(--navy);
        text-decoration: none;
      }

      .logo-name:focus-visible {
        border-radius: 3px;
        outline: 2px solid var(--amber);
        outline-offset: 4px;
      }

      .logo-tagline {
        font-family: Arial, sans-serif;
        font-size: 10px;
        color: #aaa;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        margin-top: 3px;
      }

      .nav-row {
        display: flex;
        overflow-x: auto;
      }

      .nav-lnk {
        font-family: Arial, sans-serif;
        font-size: 12px;
        font-weight: 600;
        color: #666;
        padding: 10px 20px;
        white-space: nowrap;
        cursor: pointer;
        border-bottom: 3px solid transparent;
        transition: all 0.2s;
      }

      .nav-lnk:hover,
      .nav-lnk.active {
        color: var(--sage);
        border-bottom-color: var(--sage);
      }

      .page-wrap {
        max-width: 900px;
        margin: 0 auto;
        padding: 40px 16px 80px;
      }

      .category-pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: var(--sage3);
        color: var(--sage);
        font-family: Arial, sans-serif;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.09em;
        padding: 5px 14px;
        border-radius: 20px;
        margin-bottom: 16px;
      }

      h1.art-title {
        font-family: Georgia, serif;
        font-size: 40px;
        font-weight: 700;
        line-height: 1.18;
        color: var(--navy);
        margin-bottom: 14px;
      }

      .art-subtitle {
        font-family: Arial, sans-serif;
        font-size: 17px;
        color: var(--muted);
        line-height: 1.55;
        margin-bottom: 22px;
        font-style: italic;
        border-left: 4px solid var(--amber);
        padding-left: 16px;
      }

      .read-bar {
        display: flex;
        align-items: center;
        gap: 10px;
        font-family: Arial, sans-serif;
        font-size: 12px;
        color: #aaa;
        padding: 14px 0;
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
        margin-bottom: 36px;
      }

      .read-pill {
        background: var(--sage3);
        color: var(--sage);
        font-weight: 700;
        font-size: 11px;
        padding: 3px 10px;
        border-radius: 20px;
      }

      .article-body p { margin-bottom: 22px; }

      .lead-graf {
        font-size: 20px;
        line-height: 1.7;
        color: #1a1a1a;
        background: var(--sage3);
        border-left: 5px solid var(--sage);
        padding: 20px 24px;
        border-radius: 0 10px 10px 0;
        margin-bottom: 30px;
      }

      h2.sec-head {
        font-family: Georgia, serif;
        font-size: 26px;
        font-weight: 700;
        color: var(--navy);
        margin: 48px 0 16px;
        padding-bottom: 12px;
        border-bottom: 2px solid var(--border);
      }

      .pull-quote {
        background: linear-gradient(135deg, var(--navy), var(--navy2));
        border-radius: 14px;
        padding: 32px 36px;
        margin: 40px 0;
        position: relative;
        overflow: hidden;
      }

      .pull-quote::before {
        content: '\201C';
        font-size: 130px;
        color: rgba(255,255,255,0.04);
        position: absolute;
        top: -10px;
        left: 16px;
        font-family: Georgia, serif;
        line-height: 1;
      }

      .pq-text {
        font-family: Georgia, serif;
        font-size: 20px;
        font-style: italic;
        color: #e8f2eb;
        line-height: 1.7;
        position: relative;
        z-index: 1;
        margin-bottom: 14px;
      }

      .pq-source {
        font-family: Arial, sans-serif;
        font-size: 12px;
        color: rgba(255,255,255,0.4);
        position: relative;
        z-index: 1;
      }

      .highlight-box {
        background: #fffaf3;
        border: 1px solid #f0d9b0;
        border-left: 5px solid var(--amber);
        border-radius: 0 10px 10px 0;
        padding: 22px 26px;
        margin: 32px 0;
        font-family: Arial, sans-serif;
        font-size: 14px;
        color: #4a3a20;
        line-height: 1.75;
      }

      .highlight-box strong {
        display: block;
        font-size: 15px;
        color: var(--amber);
        margin-bottom: 8px;
      }

      .habit-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
        gap: 16px;
        margin: 28px 0;
      }

      .habit-card {
        background: #fff;
        border: 1px solid var(--border);
        border-top: 4px solid var(--sage);
        border-radius: 10px;
        padding: 22px 18px;
        transition: box-shadow 0.2s, transform 0.2s;
      }

      .habit-card:hover {
        box-shadow: 0 6px 22px rgba(74,124,89,0.13);
        transform: translateY(-2px);
      }

      .hc-icon {
        font-size: 32px;
        margin-bottom: 10px;
      }

      .hc-title {
        font-family: Arial, sans-serif;
        font-size: 13px;
        font-weight: 700;
        color: var(--sage);
        margin-bottom: 7px;
      }

      .hc-text {
        font-family: Arial, sans-serif;
        font-size: 13px;
        color: #666;
        line-height: 1.6;
      }

      .timeline { margin: 30px 0; }

      .tl-item {
        display: flex;
        gap: 20px;
        margin-bottom: 24px;
        align-items: flex-start;
      }

      .tl-time {
        background: var(--sage);
        color: #fff;
        font-family: Arial, sans-serif;
        font-size: 11px;
        font-weight: 700;
        padding: 7px 10px;
        border-radius: 8px;
        white-space: nowrap;
        flex-shrink: 0;
        margin-top: 2px;
        text-align: center;
        min-width: 70px;
      }

      .tl-body { flex: 1; }

      .tl-title {
        font-family: Arial, sans-serif;
        font-size: 15px;
        font-weight: 700;
        color: var(--navy);
        margin-bottom: 5px;
      }

      .tl-desc {
        font-family: Arial, sans-serif;
        font-size: 13px;
        color: #666;
        line-height: 1.65;
      }

      .tl-line {
        width: 2px;
        height: 18px;
        background: linear-gradient(var(--sage), var(--amber));
        margin: -8px 0 -6px 34px;
        border-radius: 2px;
      }

      .stat-strip {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
        gap: 14px;
        margin: 32px 0;
      }

      .stat-card {
        background: var(--navy);
        border-radius: 12px;
        padding: 22px 18px;
        text-align: center;
      }

      .sc-number {
        font-family: Georgia, serif;
        font-size: 34px;
        font-weight: 700;
        color: var(--amber2);
        line-height: 1;
        margin-bottom: 6px;
      }

      .sc-label {
        font-family: Arial, sans-serif;
        font-size: 12px;
        color: rgba(255,255,255,0.65);
        line-height: 1.5;
      }

      .cmp-table {
        width: 100%;
        border-collapse: collapse;
        margin: 28px 0;
        font-family: Arial, sans-serif;
        font-size: 13px;
      }

      .cmp-table th {
        background: var(--navy);
        color: #fff;
        padding: 12px 16px;
        font-size: 12px;
        letter-spacing: 0.03em;
        text-align: left;
      }

      .cmp-table td {
        padding: 12px 16px;
        border-bottom: 1px solid #ece8e0;
        color: #333;
        vertical-align: top;
      }

      .cmp-table tr:nth-child(even) td { background: #f6f3ec; }
      .cmp-table tr.hl td { background: var(--sage3) !important; }
      .cmp-table td:first-child { font-weight: 700; color: #111; width: 34%; }

      .faq-item {
        border-bottom: 1px solid var(--border);
        padding: 20px 0;
      }

      .faq-q {
        font-family: Arial, sans-serif;
        font-size: 15px;
        font-weight: 700;
        color: var(--navy);
        margin-bottom: 8px;
      }

      .faq-q::before {
        content: 'Q: ';
        color: var(--sage);
      }

      .faq-a {
        font-family: Arial, sans-serif;
        font-size: 14px;
        color: #666;
        line-height: 1.7;
      }

      .closing-note {
        background: linear-gradient(135deg, var(--navy), #143520);
        border-radius: 16px;
        padding: 40px 36px;
        margin: 44px 0;
        text-align: center;
      }

      .cn-eyebrow {
        font-family: Arial, sans-serif;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--amber2);
        margin-bottom: 14px;
      }

      .cn-title {
        font-family: Georgia, serif;
        font-size: 26px;
        color: #fff;
        line-height: 1.35;
        margin-bottom: 16px;
      }

      .cn-text {
        font-family: Arial, sans-serif;
        font-size: 15px;
        color: rgba(255,255,255,0.7);
        line-height: 1.7;
        max-width: 560px;
        margin: 0 auto 28px;
      }

      .cta-wrap {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
        margin: 36px 0;
      }

      .cta-btn-main {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        background: linear-gradient(135deg, #2a9d8f, #21867a);
        color: #fff;
        font-family: Arial, sans-serif;
        font-size: 16px;
        font-weight: 700;
        padding: 18px 40px;
        border-radius: 50px;
        text-decoration: none;
        letter-spacing: 0.02em;
        box-shadow: 0 4px 18px rgba(42,157,143,0.35);
        transition: transform 0.2s, box-shadow 0.2s;
        width: 100%;
        max-width: 480px;
      }

      .cta-btn-main:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 28px rgba(42,157,143,0.45);
      }

      .cta-btn-sec {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        background: linear-gradient(135deg, #2a9d8f, #21867a);
        color: #fff;
        font-family: Arial, sans-serif;
        font-size: 14px;
        font-weight: 700;
        padding: 13px 32px;
        border-radius: 50px;
        text-decoration: none;
        letter-spacing: 0.02em;
        box-shadow: 0 3px 14px rgba(42,157,143,0.30);
        transition: transform 0.2s, box-shadow 0.2s;
        width: 100%;
        max-width: 400px;
      }

      .cta-btn-sec:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 22px rgba(42,157,143,0.40);
      }

      .cta-sub {
        font-family: Arial, sans-serif;
        font-size: 11px;
        color: #aaa;
        text-align: center;
      }

      .disclaimer {
        background: #eee9e0;
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 18px 22px;
        font-family: Arial, sans-serif;
        font-size: 11px;
        color: #999;
        line-height: 1.9;
        margin-top: 36px;
      }

      .disclaimer strong {
        color: #777;
        font-size: 12px;
      }

      .site-footer {
        background: var(--navy);
        color: rgba(255, 255, 255, 0.72);
        text-align: center;
        padding: 30px 16px;
        font-family: Arial, sans-serif;
        font-size: 12px;
        line-height: 1.9;
      }

      .site-footer a {
        display: inline-block;
        border-radius: 3px;
        padding: 3px 5px;
        color: #9ee7e5;
        font-size: 12px;
        font-weight: 700;
        text-decoration: underline;
        text-decoration-thickness: 1px;
        text-underline-offset: 3px;
        transition: color 0.2s ease, background 0.2s ease;
      }

      .site-footer a:hover,
      .site-footer a:focus-visible {
        border-radius: 4px;
        outline: 2px solid var(--amber2);
        outline-offset: 2px;
        background: rgba(255, 255, 255, 0.12);
        color: #ffffff;
      }

      @media (max-width: 600px) {
        h1.art-title { font-size: 26px; }
        .logo-name { font-size: 25px; }
        .stat-strip { grid-template-columns: 1fr 1fr; }
        .pull-quote { padding: 22px 20px; }
        .closing-note { padding: 28px 20px; }
        .cta-btn-main { font-size: 14px; padding: 16px 28px; }
        .cta-btn-sec { font-size: 13px; padding: 12px 24px; }
      }
    </style>
  </Fragment>

