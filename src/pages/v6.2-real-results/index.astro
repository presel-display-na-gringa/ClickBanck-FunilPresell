  <script>
    // Ativa o tracking real dos data-event (clique + scroll)
    document.addEventListener('DOMContentLoaded', () => {
      const fired = new Set();

      function track(eventName, extra = {}) {
        // Substitua pelo seu pixel / gtag / fbq real
        if (typeof window.gtag === 'function') {
          window.gtag('event', eventName, extra);
        }
        console.log('[track]', eventName, extra);
      }

      document.querySelectorAll('[data-event="lead_cta_click"]').forEach((el) => {
        el.addEventListener('click', () => {
          track('lead_cta_click', { cta_id: el.dataset.ctaId });
        });
      });

      const scrollMarkers = document.querySelectorAll('[data-event^="scroll_"]');
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          const eventName = entry.target.dataset.event;
          if (entry.isIntersecting && !fired.has(eventName)) {
            fired.add(eventName);
            track(eventName);
          }
        });
      }, { threshold: 0.1 });

      scrollMarkers.forEach((el) => observer.observe(el));

      track('page_view');
    });
  </script>

