        font-family: Georgia, serif;
        font-size: 22px;
        margin-bottom: 10px;
        color: #e8c96d;
      }

      .info-strip p {
        font-family: Arial, sans-serif;
        font-size: 14px;
        color: rgba(255, 255, 255, 0.82);
        margin-bottom: 20px;
      }

      .disclaimer-strip {
        background: #f0ede6;
        border: 1px solid #ddd;
        border-radius: 8px;
        padding: 18px 20px;
        font-family: Arial, sans-serif;
        font-size: 11px;
        color: #777;
        line-height: 1.7;
        margin-top: 32px;
      }

