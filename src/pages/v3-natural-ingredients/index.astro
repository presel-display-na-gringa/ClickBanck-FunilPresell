        font-size: 13px;
      }

      .sidebar-info h4 {
        font-size: 14px;
        font-weight: 700;
        color: #fff;
        margin-bottom: 12px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        padding-bottom: 8px;
      }

      .sidebar-stat {
