      }

      .sidebar-stat-icon {
        font-size: 16px;
        flex-shrink: 0;
      }

      .sidebar-fact {
        background: #eaf4ea;
        border-left: 4px solid #2e7d32;
        border-radius: 0 10px 10px 0;
        padding: 16px 14px;
        font-family: Arial, sans-serif;
        font-size: 13px;
        color: #2c4a2c;
      }

      .sidebar-fact h4 {
        font-size: 13px;
        font-weight: 700;
        color: #1b5e20;
        margin-bottom: 8px;
      }

      .product-widget {
        background: #fff;
        border: 1px solid #e0dbd0;
        border-radius: 12px;
        padding: 22px 18px;
        text-align: center;
      }

      .site-footer {
        background: #1a1a1a;
        color: rgba(255, 255, 255, 0.45);
        text-align: center;
        padding: 24px 16px;
        font-family: Arial, sans-serif;
        font-size: 11px;
        line-height: 1.7;
      }

      .site-footer a {
        color: rgba(255, 255, 255, 0.6);
        text-decoration: underline;
      }

      @media (max-width: 768px) {
        .page-wrap {
          grid-template-columns: 1fr;
        }

        .sidebar {
          order: 2;
        }
      }

      @media (max-width: 600px) {
        .article-title {
          font-size: 24px;
        }

        .masthead-nav {
          gap: 12px;
          flex-wrap: wrap;
        }

        .btn-red,
        .btn-green,
        .btn-yellow {
          width: 100%;
          padding: 15px 20px;
        }
      }
    </style>
  </Fragment>

  <div class="progress-bar" id="progressBar"></div>

  <div class="top-banner">
    <strong>HEALTH WATCH DAILY</strong>
    &nbsp;·&nbsp; Independent Wellness Information
    &nbsp;·&nbsp; Updated: July 2026
  </div>

  <header class="masthead">
    <a href="/" class="masthead-logo">Health<span>Watch</span>Daily</a>

    <div class="masthead-meta">
      Wellness Information<br />
      <span style="color: #c0392b; font-weight: 700;">SUPPLEMENT EDUCATION</span>
    </div>

    <nav class="masthead-nav" aria-label="Main navigation">
