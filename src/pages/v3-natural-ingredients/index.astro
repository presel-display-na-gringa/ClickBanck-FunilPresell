      }

      .faq-q {
        font-family: Arial, sans-serif;
        font-size: 15px;
        font-weight: 700;
        color: #1a1a1a;
        margin-bottom: 8px;
      }

      .faq-q::before {
        content: "Q: ";
        color: #c0392b;
      }

      .faq-a {
        font-family: Arial, sans-serif;
