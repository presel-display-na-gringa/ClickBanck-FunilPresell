        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family: Georgia, serif;
        background: #f4f1eb;
        color: #1e1e1e;
        font-size: 17px;
        line-height: 1.8;
      }

      .progress-bar {
        position: fixed;
        top: 0;
        left: 0;
        height: 3px;
        width: 0%;
        background: #c0392b;
        z-index: 9999;
        transition: width 0.2s ease;
      }

      .top-banner {
        background: #1a1a1a;
        color: #f0e6c8;
        text-align: center;
