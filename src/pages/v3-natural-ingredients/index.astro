        color: #555;
      }

      .btn-wrap {
        display: flex;
        justify-content: center;
        margin: 28px 0;
      }

      .btn-red,
      .btn-green,
      .btn-yellow {
        display: inline-block;
        font-family: Arial, sans-serif;
        font-size: 15px;
        font-weight: 800;
        padding: 16px 44px;
        border-radius: 50px;
        text-align: center;
        text-decoration: none;
        border: none;
        letter-spacing: 0.02em;
        transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
      }

      .btn-red {
        background: #c0392b;
        color: #fff !important;
        box-shadow: 0 5px 18px rgba(192, 57, 43, 0.45);
      }

      .btn-red:hover {
        background: #a93226;
        transform: translateY(-2px);
      }

      .btn-green {
        background: #1b5e20;
        color: #fff !important;
        box-shadow: 0 5px 18px rgba(27, 94, 32, 0.45);
